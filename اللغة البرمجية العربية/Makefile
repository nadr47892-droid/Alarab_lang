# =========================
# اسم البرنامج
# =========================
TARGET = اللغة

# =========================
# المترجم
# =========================
CC = gcc

# =========================
# خيارات الترجمة
# =========================
CFLAGS = -Wall -Wextra -O2

# =========================
# مسارات الرؤوس (Headers)
# =========================
INCLUDES = \
-Iالتنفيذ \
-Iالمحرك \
-Iفهم_اللغة \
-Iنظامي \
-Iالقاموس \
-Iالمحرك_الرياضي \
-Iالمحرك_الرياضي/المتغيرات \
-Iالمحرك_الرياضي/العمليات_الحسابية_الاساسية/المقارنات \
-Iالمحرك_الرياضي/العمليات_الحسابية_الاساسية/الجذور \
-Iالمحرك_الرياضي/العمليات_الحسابية_الاساسية/المعادلات_الاسية \
-Iالمحرك_الرياضي/الاعداد_الضخمة \
-Iالمحرك_الرياضي/الدوال_المثلثية \
-Iالمحرك_الرياضي/الثوابت \
-Iالمحرك_الرياضي/العمليات_الحسابية_الاساسية \
-Iمحرك_الدوال

# =========================
# ملفات المصدر
# =========================
SOURCES = \
المشغل_الرئيسي.c \
التنفيذ/المنفذ.c \
المحرك/المحرك.c \
فهم_اللغة/مفسر_العمليات.c \
نظامي/محرك_الاشارات.c \
المحرك_الرياضي/المحرك_الرياضي.c \
المحرك_الرياضي/المتغيرات/محرك_المتغيرات.c \
المحرك_الرياضي/الثوابت/محرك_الثوابت.c \
المحرك_الرياضي/العمليات_الحسابية_الاساسية/المقارنات/محرك_المقارنات.c \
المحرك_الرياضي/العمليات_الحسابية_الاساسية/الجذور/محرك_الجذور.c \
المحرك_الرياضي/العمليات_الحسابية_الاساسية/المعادلات_الاسية/محرك_الاسس.c \
المحرك_الرياضي/الاعداد_الضخمة/محرك_الاعداد_الضخمة.c \
المحرك_الرياضي/الدوال_المثلثية/محرك_الدوال_المثلثية.c \
المحرك_الرياضي/العمليات_الحسابية_الاساسية/محرك_العمليات_الحسابية_الاساسية.c \
محرك_الدوال/محرك_الدالة.c 


# =========================
# الهدف الافتراضي
# =========================
all:
	$(CC) $(CFLAGS) $(SOURCES) $(INCLUDES) -lm -o $(TARGET)

# =========================
# تشغيل البرنامج
# =========================
run: all
	./$(TARGET)

# =========================
# تنظيف
# =========================
clean:
	rm -f $(TARGET)
